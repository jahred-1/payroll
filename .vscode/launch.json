{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Open Browser (XAMPP)",
            "type": "php",
            "request": "launch",
            "url": "http://localhost/Payroll/",
            "browser": "edge"
        },
        {
            "name": "Launch Browser & Run Server",
            "type": "php",
            "request": "launch",
            "program": "${workspaceRoot}/index.php",
            "cwd": "${workspaceRoot}",
            "port": 9003,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Development Server \\(http://localhost:([0-9]+)\\) started",
                "uriFormat": "http://localhost:%s"
            },
            "runtimeArgs": [
                "-S",
                "localhost:8000",
                "-t",
                "${workspaceRoot}"
            ],
            "runtimeExecutable": "C:\\xampp\\php\\php.exe"
        },
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003
        },
        {
            "name": "Launch currently open script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 9003,
            "runtimeExecutable": "C:\\xampp\\php\\php.exe"
        }
    ]
}
